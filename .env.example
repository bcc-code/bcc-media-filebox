# Copy to .env and adjust. The .env file is git-ignored.

# --- Core ---
PORT=8080
UPLOAD_DIR=./uploads
DB_PATH=./filebox.db
# Absolute base URL when behind a reverse proxy. Leave empty for local dev.
# BASE_URL=https://upload.example.com

# --- Upload targets (at least one required) ---
TARGET_1_NAME=RawMaterial
TARGET_1_DIR=./uploads
# TARGET_2_NAME=Processed
# TARGET_2_DIR=/srv/uploads/processed

# --- OAuth (optional) ---
# Leave every OIDC_* var unset to run in guest-only mode.
# SESSION_KEY is required only when at least one provider is configured.
# Generate with: openssl rand -base64 48
# SESSION_KEY=replace-with-32-plus-random-bytes-base64

# BCC Login
# OIDC_BCC_ISSUER=https://login.bcc.no/
# OIDC_BCC_CLIENT_ID=
# OIDC_BCC_CLIENT_SECRET=
# OIDC_BCC_DISPLAY_NAME=BCC Login
# OIDC_BCC_SCOPES=openid profile email

# Microsoft Entra ID (Azure AD)
# OIDC_AZURE_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# OIDC_AZURE_CLIENT_ID=
# OIDC_AZURE_CLIENT_SECRET=
# OIDC_AZURE_DISPLAY_NAME=Microsoft
# OIDC_AZURE_SCOPES=openid profile email
